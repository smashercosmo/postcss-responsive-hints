{
  "name": "root",
  "version": "0.1.0",
  "private": true,
  "description": "PostCSS plugin that makes it easier to write responsive styles",
  "scripts": {
    "build": "turbo build --filter=!root",
    "dev": "turbo dev --filter=!root",
    "test": "turbo test --filter=!root",
    "clean": "turbo clean --filter=!root && rm -rf node_modules && rm -rf .turbo",
    "test:project": "f() { vitest run --project=\"$1\"; }; f",
    "ci:version": "changeset version && pnpm ci",
    "actions:update": "actions-up"
  },
  "keywords": [
    "postcss",
    "postcss-plugin"
  ],
  "author": "Vladislav Shkodin <smashercosmo@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/smashercosmo/postcss-responsive-hints/issues"
  },
  "homepage": "https://github.com/smashercosmo/postcss-responsive-hints#readme",
  "peerDependencies": {
    "postcss": ">=8"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@postcss-responsive-hints/tsconfig": "workspace:*",
    "@postcss-responsive-hints/vitest": "workspace:*",
    "@pshevche/act-test-runner": "^1.0.2",
    "@types/node": "catalog:types",
    "actions-up": "catalog:tools",
    "clean-publish": "^7.1.0",
    "tsdown": "catalog:dev",
    "turbo": "catalog:tools",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "warn"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0"
    }
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
