{
  "name": "root",
  "type": "module",
  "description": "PostCSS plugin that makes it easier to write responsive styles",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "actions:update": "actions-up",
    "beachball:change": "beachball change",
    "beachball:change": "beachball change",
    "beachball:check": "beachball check",
    "release": "beachball publish --no-publish",
    "prepublishOnly": "pnpm build",
    "clean": "find . -type d \\( -name \"node_modules\" -o -name \"dist\" -o -name \".turbo\" \\) -prune -exec rm -rf {} +"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smashercosmo/postcss-responsive-hints.git"
  },
  "keywords": [
    "postcss",
    "postcss-plugin"
  ],
  "author": "Vladislav Shkodin <smashercosmo@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/smashercosmo/postcss-responsive-hints/issues"
  },
  "homepage": "https://github.com/smashercosmo/postcss-responsive-hints#readme",
  "peerDependencies": {
    "postcss": ">=8"
  },
  "devDependencies": {
    "@types/node": "catalog:types",
    "actions-up": "catalog:tools",
    "beachball": "catalog:tools",
    "tsdown": "catalog:dev",
    "turbo": "catalog:tools",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": ">=24.0.0"
    }
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "beachball": {
    "branch": "main"
  }
}
