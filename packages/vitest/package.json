{
  "name": "@postcss-responsive-hints/vitest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist && rm -rf package",
    "postbuild": "rm -rf ./package && clean-publish"
  },
  "devDependencies": {
    "@postcss-responsive-hints/tsconfig": "workspace:*",
    "@postcss-responsive-hints/tsdown": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=8",
    "vitest": ">=4"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "directory": "package"
  }
}
